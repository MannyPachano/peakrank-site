---
import PeakLayout from "../layouts/PeakLayout.astro";
---

<PeakLayout
  title="Thank You | PeakRanking Digital Solutions"
  description="Thanks for contacting PeakRanking Digital Solutions. We'll be in touch soon."
  canonicalPath="/thanks"
  robots="noindex, follow"
>
  <header class="page-header">
    <div class="stars"></div>
    <div class="page-header-inner">
      <div class="page-header-eyebrow">Contact</div>
      <h1>Message received</h1>
      <p>
        Thanks for reaching out. We got your note and will reply within 24 hours. If it&rsquo;s urgent,
        call <a href="tel:6787932445">(678) 793-2445</a>.
      </p>
      <p style="margin-top: 1.5rem;">
        <a href="/" class="btn-primary">Back to home</a>
      </p>
    </div>
  </header>
</PeakLayout>
